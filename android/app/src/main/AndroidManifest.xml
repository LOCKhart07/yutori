<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- API 33+ runtime permission for budget-threshold notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Forex rate fetches (business-logic-spec §5). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- In-app autoupdater (plans/autoupdater-spec.md §8). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".SpendWiseApp"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpendWise">

        <!-- Lets Macrobenchmark / Android Studio profilers capture traces
             from release-shaped builds. Ignored below API 29. -->
        <profileable
            android:shell="true"
            tools:targetApi="29" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SpendWise">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receives PackageInstaller.Session outcomes for the in-app
             autoupdater (plans/autoupdater-spec.md §4.5 & §8). Unexported —
             only our own install sessions target it. -->
        <receiver
            android:name=".update.UpdateInstallResultReceiver"
            android:exported="false" />
    </application>

</manifest>
