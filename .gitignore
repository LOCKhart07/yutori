# Claude Code local state
.claude

# Local audit / signoff artifacts that name the PII patterns we scrubbed
PII_AUDIT_SIGNOFF.md

# Feasibility dataset — used to contain real SMS bodies. Whole directory
# deleted from the repo; any future dumps of real SMS data should stay
# local-only under this path.
feasibility/
# Parser/classifier JSON fixtures — previously seeded from real SMS data
# and scrubbed from the repo. Keep any local-only dumps gitignored.
android/parser/src/test/resources/fixtures/

# ---------------------------------------------------------------------------
# Gradle / Kotlin JVM
# ---------------------------------------------------------------------------
.gradle/
**/build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/**/build/
.kotlin/

# Local Gradle properties (may contain per-machine overrides, SDK paths)
local.properties

